root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.md]
indent_size = 2
trim_trailing_whitespace = false

[*.{yaml,yml}]
indent_size = 2

[*.py]
indent_size = 4
max_line_length = 100

[*.jsonl]
insert_final_newline = true
