# ---
# class: operational
# authority: canonical
# stability: stable
# loaded_by_agent: yes
# ---
#
# acw-state.yaml — instance self-contract for {{PROJECT_NAME}}
#
# Single authoritative statement of this instance's current truth. Edited only
# via a decision-log entry. Every edit bumps `version` or `last_reconciled`.

project:
  name: "{{PROJECT_NAME}}"
  code: "{{PROJECT_CODE}}"
  domain: "{{DOMAIN}}"

version: "0.1.0"
last_reconciled: "{{DATE}}"
last_reconciled_version: "0.10.0"

# Instance type — declares which substrate modules this instance uses.
# Profile defaults are documented in rules/instance-types.md.
# One of: org-brain | spec-project | coding-project | library | custom
profile: {{PROFILE}}

# Explicit module list — overrides profile defaults if both are set.
# Omit or leave null to use profile defaults.
modules:
{{MODULES_YAML}}

# Declares whether this instance publishes canonical content downstream to
# other instances. Default false — this instance is a downstream consumer of
# ACW canonical, not a publisher. Set to true ONLY if this instance becomes
# an upstream source for further-derived instances. Gates the propagation
# behavior in capture-and-metabolize Phase 2.
is_canonical_source: false

# Canonical runtime files for this instance. Files not listed are reference,
# archive, or derived.
canonical_runtime_files:
  - rules/pipeline-roles.md
  - rules/canon-governance.md
  - rules/canon-schema.yaml
  - rules/canon.yaml
  - rules/instance-hard-rules.md
  - rules/vocabulary-lint.md
  - rules/capability-broker.md
  - rules/decision-tracking.md
  - rules/promotion-ritual.md
  - rules/skill-format.md
  - rules/task-tracking.md
  - rules/incident-tracking.md
  - .acw/decisions/INDEX.md
  - .acw/DEFERRED.md
  - .acw/glossary/INDEX.md
  - threat-model.md
  - .acw/incidents.jsonl
  - .acw/tasks-status.md
  - .acw/build-log.md
  - tools/lint-vocab.py
  - tools/log-incident.py
  - AGENTS.md
  - .acw/acw-state.yaml

# Files auto-loaded into agent context at session start. Hosts implement via
# their native mechanism (Claude Code: @-imports in CLAUDE.md). See AGENTS.md
# directive 7. Each entry MUST declare a claim per rules/auto-load-discipline.md
# (earned in v0.9.0). Default canonical four — instance can override with
# additional entries (each requires a structured claim) or drop entries (each
# drop requires a decision-log entry). Bare-path entries are accepted but
# flagged as legacy-pending-review by /acw-instance audit.
auto_load_at_session_start:
  - path: .acw/decisions/INDEX.md
    claim: "Recently decided history must be visible to agents at session start; without it agents re-litigate settled choices. INDEX is the thin auto-loaded surface; bodies in entries/ load on demand."
    earned_by: structural
  - path: rules/instance-hard-rules.md
    claim: "Stop-work rules must be visible to every agent at session start; loading them on demand is too late."
    earned_by: structural
  - path: .acw/tasks-status.md
    claim: "Pending work surface must be visible at session start; without it agents propose duplicate work and lose continuity."
    earned_by: structural
  - path: .acw/glossary/INDEX.md
    claim: "Vocabulary canon prevents drift to colloquial English in agent output. INDEX is the thin auto-loaded surface; bodies in entries/ load on demand."
    earned_by: structural

# Cross-repo write surfaces explicitly allowed. Empty list means project
# artifacts stay in the project repo (vault-boundary discipline).
cross_repo_writes: []

# Substrate files that diverge from ACW canonical with an absorption
# candidate sent upstream awaiting review. Schema in
# rules/multi-instance-topology.md.
divergent_pending_review: []

# Substrate files or directories that intentionally diverge from ACW
# canonical and will not be promoted upstream. Each entry requires a
# decision-log entry naming the rationale.
instance_specific_substrate: []

# Threshold for /acw-instance upgrade adopt-mode. Above this count of
# non-canonical markdown files in decisions/ or rules/, adopt-mode bails
# and points at /acw-instance audit.
adopt_mode_organic_threshold: 5

# Optional synapse log path for operator-personal cross-project day-index.
# Empty/null disables Phase 4 of capture-and-metabolize.
synapse_log_path: null

# Voice references applied during transcript cleanup (capture-and-metabolize
# Phase 1). Empty list means no voice opinion.
voice: []

# Declarative registry of env-var secrets this instance's skills may require.
# Each entry: name (env var), required_by (skill/verb), when (always |
# on-opt-in | on-feature-X), notes (one-line). Operator supplies values via
# per-instance .env (gitignored) or shell env — never committed. See
# rules/instance-current-manifest.md § "env_secrets block — v0.10.1".
# Uncomment and populate when an opt-in feature requires an external API.
# env_secrets:
#   - name: GEMINI_API_KEY
#     required_by: "/codemap rebuild --semantic"
#     when: on-opt-in
#     notes: "Graphify Stage 2 semantic extraction. AST-only default works without this."
env_secrets: []

deferred_canonical_source: .acw/DEFERRED.md
deferred_derived_view: .acw/deferred/
deferred_drift_check: tools/log-incident.py check-drift

role_schema:
  mode: four-group-normative
  normative_groups:
    - orchestrator
    - pipeline-worker
    - guardian
    - broker-sideband
  informative_appendix: sixteen-role-taxonomy
  appendix_status: informative-only

canon_authority:
  mode: n-authority
  default_value: operator
  declared_in: rules/instance-hard-rules.md
  schema_field: approval_authority
  schema_type: string

decision_tracking:
  mode: wiki
  index: .acw/decisions/INDEX.md
  entries_dir: .acw/decisions/entries
  open_questions_dir: .acw/decisions/open-questions
  constraints_dir: .acw/decisions/constraints
  archive_pattern: ".acw/decisions/decision-log-YYYY-Q*.md"
  regenerate_index_cmd: "python tools/migrate_to_wiki.py"
  entry_frontmatter_required: [id, title, date, status, kind, updated]
  status_values: [proposed, accepted, superseded, deprecated, rejected, open, partial-resolved, resolved]
  kind_values: [decision, open-question, constraint]

glossary:
  mode: wiki
  index: .acw/glossary/INDEX.md
  entries_dir: .acw/glossary/entries
  regenerate_index_cmd: "python tools/migrate_to_wiki.py"
  entry_frontmatter_required: [term, status]
  status_values: [active, deprecated]

# Substrate file paths. v0.10.0+ canonical shape: ACW operator-metadata
# substrate lives under .acw/; rules/ stays at workspace root per D-ACW-051;
# project artifacts (research/, threat-model.md, etc.) stay at root.
# The bookend skills read from this block; instances may override any path.
paths:
  decisions_index: .acw/decisions/INDEX.md
  decisions_entries_dir: .acw/decisions/entries
  decisions_open_questions_dir: .acw/decisions/open-questions
  decisions_constraints_dir: .acw/decisions/constraints
  tasks_status: .acw/tasks-status.md
  build_log: .acw/build-log.md
  glossary_index: .acw/glossary/INDEX.md
  glossary_entries_dir: .acw/glossary/entries
  threat_model: threat-model.md
  incidents: .acw/incidents.jsonl
  evolution: research/evolution.md
  sources: research/sources.md
  research_state: research/research-state.yaml
  problem_framing: research/01-problem-framing.md
  session_captures_dir: .acw/sessions
  research_queries_dir: research/queries
  research_queries_consumed_dir: research/queries/_consumed
  raw_dir: .acw/raw
  plans_dir: .acw/plans
  briefings_dir: .acw/briefings
  inbox_dir: .acw/inbox
  archives_dir: .acw/archives

release_gates:
  - "tools/lint-vocab.py exits 0 on this instance's content"
  - "tools/log-incident.py check-drift exits 0"
  - "python -m unittest discover tests exits 0"
  - "every .md file has class/authority/stability/loaded_by_agent frontmatter"

earn_by_incident:
  enabled: true
  threshold_severity: med
  threshold_count: 3
  ledger: incidents.jsonl
  exception: "single-incident activation triggers declared per-primitive in DEFERRED.md"
